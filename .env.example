# =============================================================================
# iGOT Deterministic Chatbot — Environment Configuration
# =============================================================================
# Copy to .env and fill in real values.
# =============================================================================

# --- iGOT Chatbot runtime -----------------------------------------------------
IGOT_ENV=dev                            # dev | staging | prod
LOG_LEVEL=INFO
IGOT_WEB_SESSION_TTL_MINUTES=30         # web + mobile app (mins); WhatsApp = 1440 (24h)

# --- Database -----------------------------------------------------------------
POSTGRES_URL=postgresql+asyncpg://igot_chatbot:password@karmayogi-pg:5432/igot_chatbot

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://karmayogi-redis:6379/3
IGOT_REDIS_NAMESPACE=igot_chatbot

# --- Auth (Karmayogi Keycloak) ------------------------------------------------
# JWKS URL and issuer are auto-derived from KEYCLOAK_HOST + KEYCLOAK_REALM.
KEYCLOAK_HOST=https://portal.igotkarmayogi.gov.in
KEYCLOAK_REALM=sunbird
# AUTH_DISABLED: true = bypass JWT (dev/local only) — NEVER true in staging/prod; enforced via IGOT_ENV=prod
AUTH_DISABLED=false
AUTH_HEADER_NAME=x-authenticated-user-token
# AUTH_REQUIRED_ROLE: role that must be in user_roles claim; empty = skip check
AUTH_REQUIRED_ROLE=

# --- LLM ----------------------------------------------------------------------
LLM_PROVIDER=vertex                     # vertex | vllm
LLM_KILL_SWITCH=false                   # true forces template-only mode, skips LLM
LLM_MAX_CALLS_PER_SESSION=1
LLM_TIMEOUT_SECONDS=8

# Vertex AI (primary)
GENAI_MODEL_NAME=gemini-2.5-flash
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# vLLM (self-hosted alternative — set LLM_PROVIDER=vllm to use)
LOCAL_LLM_API_BASE=http://localhost:11435/v1

# --- Zoho Desk ----------------------------------------------------------------
ZOHO_BASE_URL=https://desk.zoho.in/api/v1
ZOHO_OAUTH_BASE=https://accounts.zoho.in
ZOHO_REFRESH_TOKEN=your-refresh-token
ZOHO_CLIENT_ID=your-client-id
ZOHO_CLIENT_SECRET=your-client-secret
ZOHO_ORG_ID=your-org-id
ZOHO_DEPARTMENT_ID=your-dept-id

# --- Karmayogi platform APIs --------------------------------------------------
KARMAYOGI_API_KEY=your-api-key
# Internal deployments: http://kong:8000  |  Local dev: https://portal.uat.karmayogibharat.net
KARMAYOGI_PORTAL_BASE_URL=http://kong:8000

# --- Langfuse (observability) -------------------------------------------------
# LANGFUSE_ENABLED: false = fully disabled, no overhead (default for new envs)
# Set to true + provide keys to activate user/session-level tracing.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST: cloud.langfuse.com (cloud) or self-hosted URL
LANGFUSE_HOST=https://cloud.langfuse.com
# 1.0 = all requests; lower in prod (e.g. 0.1) to control trace volume
LANGFUSE_SAMPLE_RATE=1.0

# --- Presidio (PII redaction) -------------------------------------------------
PRESIDIO_ENABLED=true
PRESIDIO_LANGUAGE=en
PRESIDIO_INDIA_RECOGNIZERS=aadhaar,pan,ifsc,upi,in_phone,in_pin

# --- Translation --------------------------------------------------------------
# Fail-open: if all providers fail, original text is returned — never crashes a session.
TRANSLATION_ENABLED=true
TRANSLATION_PRIMARY=gemini              # gemini | google_translate | bhashini
TRANSLATION_GEMINI_TIMEOUT_S=3.0
TRANSLATION_GOOGLE_TRANSLATE_TIMEOUT_S=2.0
TRANSLATION_BHASHINI_TIMEOUT_S=4.0
GOOGLE_TRANSLATE_API_KEY=              # leave empty to use ADC (recommended)

# Bhashini (last-resort fallback)
BHASHINI_UDYAT_KEY=
BHASHINI_API_ENDPOINT=
BHASHINI_USER_ID=

# --- CORS ---------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://portal.igotkarmayogi.gov.in,http://localhost:3000

# --- YP allocation data -------------------------------------------------------
# Path to the YP allocation CSV (or XLSX) — deploy out-of-band, never commit.
# CSV format: centre_state,mdo,name,email,mobile,cc_email  (header row required)
# Leave empty to start with no YP data (flow degrades gracefully).
YP_ALLOCATION_FILE=/app/data/yp_allocation.csv

# --- Local testing ------------------------------------------------------------
# Used as default user_id when AUTH_DISABLED=true and no token is sent.
IGOT_TEST_USER_ID=
